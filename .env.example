# Root environment variables for local development

# MongoDB
MONGODB_URI=mongodb://mongodb:27017/ai-edu-platform

# Redis
REDIS_URL=redis://redis:6379

# Ollama local model server
OLLAMA_URL=http://ollama:11434

# JWT secret for all backend services
JWT_SECRET=replace-with-secure-secret

# Service ports
AUTH_SERVICE_PORT=4001
AI_SERVICE_PORT=4002
CHAT_SERVICE_PORT=4003
NOTES_SERVICE_PORT=4004
COMMUNITY_SERVICE_PORT=4005
NOTIFICATION_SERVICE_PORT=4006
WEB_PORT=4173

# Frontend
FRONTEND_URL=http://localhost:4173
